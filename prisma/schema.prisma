generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id           Int           @id @default(autoincrement())
  openid       String        @unique @db.VarChar(100)
  phone        String?       @db.VarChar(20)
  avatar       String?       @db.VarChar(500)
  nickname     String?       @db.VarChar(100)
  role         String        @default("user") @db.VarChar(20)
  lastLogin    DateTime?     @map("last_login")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  batches      Batch[]
  userCompanies UserCompany[]

  @@index([openid])
  @@index([phone])
  @@index([role])
  @@map("users")
}

// 公司表
model Company {
  id            Int           @id @default(autoincrement())
  name          String        @db.VarChar(200)        // 公司名称
  code          String        @unique @db.VarChar(50) // 公司邀请码，用于绑定
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  userCompanies UserCompany[]
  batches       Batch[]

  @@index([code])
  @@map("companies")
}

// 用户-公司关联表（多对多）
model UserCompany {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  companyId   Int      @map("company_id")
  role        String   @default("member") @db.VarChar(20) // owner=创建者, member=成员
  isDefault   Boolean  @default(false) @map("is_default") // 是否为当前选中公司
  joinedAt    DateTime @default(now()) @map("joined_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("user_companies")
}

// 批次表
model Batch {
  id               Int          @id @default(autoincrement())
  batchNo          String       @unique @db.VarChar(50)
  productName      String       @db.VarChar(100)
  productBatchNo   String       @db.VarChar(50)
  componentName    String       @db.VarChar(100)
  componentBatchNo String       @db.VarChar(50)
  auditStatus      String       @default("pending") @db.VarChar(20)
  auditRemark      String?      @db.VarChar(500)
  userId           Int          @map("user_id")
  companyId        Int          @map("company_id")
  user             User         @relation(fields: [userId], references: [id])
  company          Company      @relation(fields: [companyId], references: [id])
  photos           BatchPhoto[]
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([userId])
  @@index([companyId])
  @@index([auditStatus])
  @@index([productName])
  @@map("batches")
}

// 批次照片表
model BatchPhoto {
  id        Int      @id @default(autoincrement())
  batchId   Int      @map("batch_id")
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  category  Int      // 1-14，对应照片分类
  url       String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([batchId])
  @@index([category])
  @@map("batch_photos")
}
