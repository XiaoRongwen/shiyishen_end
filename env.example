########################################
# 🖥️ Server Configuration（服务器配置）
########################################

PORT=4000
# 应用运行端口号，例如 4000 表示服务在 http://localhost:4000 启动。

NODE_ENV=development
# 运行环境：可选 development（开发）、production（生产）、test（测试）。


########################################
# 🗄️ Database Configuration（数据库配置）
########################################

DATABASE_URL="mysql://username:password@localhost:3306/db_name"
# 数据库连接字符串：
# 格式为 mysql://用户名:密码@主机:端口/数据库名

# 数据库连接池配置
DB_CONNECTION_LIMIT=10
# 连接池最大连接数，建议根据服务器性能调整

DB_CONNECT_TIMEOUT=60000
# 连接超时时间（毫秒），默认60秒

DB_QUERY_TIMEOUT=10000
# 查询超时时间（毫秒），默认10秒

DB_POOL_TIMEOUT=10000
# 连接池获取连接超时时间（毫秒），默认10秒

DB_IDLE_TIMEOUT=600000
# 空闲连接超时时间（毫秒），默认10分钟

DB_MAX_LIFETIME=1800000
# 连接最大生命周期（毫秒），默认30分钟


########################################
# 🔑 JWT Configuration（JWT 配置）
########################################

JWT_SECRET="your-super-secret-jwt-key-here-make-it-long-and-random-at-least-32-characters"
# JWT 密钥，用于签发和验证 token，一定要足够长和随机。

JWT_EXPIRES_IN=24h
# Access Token 有效期，例如 24h 表示 24 小时。

JWT_REFRESH_EXPIRES_IN=7d
# Refresh Token 有效期，例如 7d 表示 7 天。

JWT_ISSUER=backend-api
# 签发者（issuer），可用于验证 token 来源。

JWT_AUDIENCE=frontend-app
# 受众（audience），可用于限制 token 使用的对象。


########################################
# 🌐 CORS Configuration（跨域配置）
########################################

CORS_ORIGIN=http://localhost:3000
# 允许跨域访问的前端地址，例如 React 或 Vue 本地开发服务器。


########################################
# 🔒 Password Policy Configuration（密码策略配置）
########################################

PASSWORD_MIN_LENGTH=6
# 密码最小长度

PASSWORD_MAX_LENGTH=128
# 密码最大长度


########################################
# 🚦 Rate Limiting Configuration（限流配置）
########################################

RATE_LIMIT_WINDOW_MS=900000
# 限流时间窗口（毫秒），例如 900000ms = 15分钟

RATE_LIMIT_MAX_REQUESTS=5
# 在时间窗口内最多允许的请求数

# Redis配置（多实例部署推荐）
# REDIS_URL=redis://localhost:6379
# 如果配置了Redis，建议使用 redisRateLimit.ts 中的Redis限流中间件


########################################
# 🔐 Bcrypt Configuration（加密配置）
########################################

BCRYPT_SALT_ROUNDS=12
# Bcrypt 加密盐的复杂度，值越大加密越慢但更安全，建议 10~12。


########################################
# 📁 File Upload Configuration（文件上传配置）
########################################

UPLOAD_DIR=uploads
# 文件上传目录，相对于项目根目录

MAX_FILE_SIZE=10485760
# 最大文件大小（字节），10485760 = 10MB

ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,webp
# 允许上传的文件类型，用逗号分隔


########################################
# ☁️ Aliyun OSS Configuration（阿里云 OSS 配置）
########################################

OSS_REGION=oss-cn-hangzhou
# OSS 地域，例如 oss-cn-hangzhou、oss-cn-shanghai

OSS_ACCESS_KEY_ID=your_access_key_id
# 阿里云 AccessKey ID（建议使用 RAM 子账号，只授予 OSS 写权限）

OSS_ACCESS_KEY_SECRET=your_access_key_secret
# 阿里云 AccessKey Secret

OSS_BUCKET=your_bucket_name
# OSS Bucket 名称

OSS_CDN_DOMAIN=
# 可选：绑定的 CDN 加速域名（不含 https://），留空则使用 OSS 默认域名


########################################
# 📱 WeChat Configuration（微信配置）
########################################

WECHAT_APP_ID=your_wechat_app_id
# 微信公众号的 AppID，从微信公众平台获取

WECHAT_APP_SECRET=your_wechat_app_secret
# 微信公众号的 AppSecret，从微信公众平台获取

########################################
# 🔴 Redis Configuration（Redis 配置）
########################################

REDIS_URL=redis://localhost:6379
# Redis 连接 URL，格式为 redis://[密码@]主机:端口/数据库号
# 例如：
#   - redis://localhost:6379          # 无密码
#   - redis://:password@localhost:6379 # 有密码
#   - redis://redis.example.com:6380  # 远程 Redis

REDIS_PASSWORD=
# Redis 密码，如果 REDIS_URL 中未包含密码，可在此设置

REDIS_DB=0
# Redis 数据库号，默认为 0


########################################
# 🎨 AI Image Generation Configuration（AI图片生成配置）
########################################

GEMINI_API_URL=https://api.example.com
# Gemini API 基础地址，用于优化提示词

GEMINI_API_KEY=your_gemini_api_key_here
# Gemini API 密钥

IMAGE_GEN_API_URL=https://api.example.com
# 图片生成 API 基础地址（Nano-banana）

IMAGE_GEN_API_KEY=your_image_gen_api_key_here
# 图片生成 API 密钥
